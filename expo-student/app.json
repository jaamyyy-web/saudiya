{
  "expo": {
    "name": "منصة العلم",
    "slug": "saudi-edu-student",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#064E3B"
    },
    "assetBundlePatterns": ["**/*"],
    "scheme": "saudiedu-auth",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.saudiedu.student",
      "buildNumber": "1",
      "infoPlist": {
        "NSFaceIDUsageDescription": "Allow $(PRODUCT_NAME) to use Face ID for authentication"
      }
    },
    "android": {
      "package": "com.saudiedu.student",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#064E3B"
      },
      "permissions": []
    },
    "plugins": [
      "expo-apple-authentication"
    ],
    "extra": {
      "eas": {
        "projectId": "YOUR_EAS_PROJECT_ID"
      }
    }
  }
}
