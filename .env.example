# GEMINI_API_KEY: Required for Gemini AI API calls.
# This is a placeholder key.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=MY_GEMINI_API_KEY

# Backend Firebase Integration Configurations
# Configure real Firebase credentials in AI Studio Secrets panel
FIREBASE_API_KEY=MY_FIREBASE_API_KEY
FIREBASE_PROJECT_ID=saudiedu-firebase-project
FIREBASE_DATABASE_URL=https://saudiedu-default-rtdb.firebaseio.com
FIREBASE_APP_ID=1:1234567890:android:abcdef123456
